{
  "require": {
    "php": ">=8.5",
    "ext-gettext": "*",
    "laminas/laminas-diactoros": "^3",
    "league/container": "^5",
    "slim/slim": "^4",
    "symfony/console": "^7",
    "psr/container": "^2",
    "vlucas/phpdotenv": "^5"
  },
  "require-dev": {
    "phpunit/phpunit": "^12"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Test\\": "tests/"
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  }
}
